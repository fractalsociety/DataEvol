8. Primary Command Surface\
Initialize repo/service\
dataevol init\
Ingest traces\
dataevol ingest --source coordinate --path ./run_artifacts/\
dataevol ingest --source biolatent --path ./biolatent_run/\
dataevol ingest --jsonl ./traces.jsonl\
Label traces\
dataevol label --run-id run_001\
Score traces\
dataevol score --run-id run_001\
Compress traces\
dataevol compress --run-id run_001\
Build datasets\
dataevol dataset build --type router\
dataevol dataset build --type critic\
dataevol dataset build --type verifier\
dataevol dataset build --type compressor\
Build benchmarks\
dataevol benchmark build --from-runs last_100\
Reflection / improvement discovery\
dataevol evolve reflect --run-id run_001\
Generate Idea PRD\
dataevol evolve idea-prd --opportunity opp_001\
Run sandbox experiment\
dataevol evolve experiment --idea ./ideas/opp_001/IDEA_PRD.md\
Compare baseline vs variant\
dataevol evolve compare --experiment exp_001\
Promote only if validated\
dataevol evolve promote --experiment exp_001\
Reject/archive failed experiment\
dataevol evolve reject --experiment exp_001\
