[paths]
db = ".dataevol/dataevol.sqlite3"
raw = ".dataevol/raw"
artifacts = ".dataevol/artifacts"

[api]
token = "dev-local-token"

[privacy]
mode = "private-local-only"

# Optional: required only for `dataevol harness` model-driven commands.
# Prefer OPENROUTER_API_KEY or DATAEVOL_MODEL_API_KEY for real secrets.
